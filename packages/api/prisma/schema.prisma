generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Shot {
  id                String    @id @default(uuid())
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  startTime         DateTime

  filePath          String
  sha256            String    @unique

  duration          Float?
  beanWeight        Float?
  drinkWeight       Float?
  drinkTds          Float?
  drinkEy           Float?

  profileTitle      String?
  grinderModel      String?
  grinderSetting    String?
  barista           String?
  beverageType      String?   // "espresso" | "filter" | null

  beanBrand         String?
  beanType          String?
  roastDate         DateTime?
  roastLevel        String?

  espressoEnjoyment Int?
  fragrance         Float?
  aroma             Float?
  flavor            Float?
  aftertaste        Float?
  acidity           Float?
  bitterness        Float?
  sweetness         Float?
  mouthfeel         Float?

  beanNotes         String?
  espressoNotes     String?
  privateNotes      String?

  shotData          String    // JSON as TEXT

  tags              Tag[]
  analysis          ShotAnalysis?

  @@index([startTime])
  @@index([beanBrand])
  @@index([beanType])
  @@index([profileTitle])
  @@index([grinderModel])
  @@index([beanWeight, drinkWeight])
  @@index([beverageType])
}

model ShotAnalysis {
  id                String    @id @default(cuid())
  shotId            String    @unique
  shot              Shot      @relation(fields: [shotId], references: [id], onDelete: Cascade)
  analysisType      String    // 'detail' or 'stats'
  aiModel           String    // 'claude-opus-4-8', 'claude-sonnet-4-6', 'gpt-4', 'gpt-4-turbo'
  barista           String    // JSON array of strings
  roaster           String    // JSON array of strings
  analyst           String    // JSON array of strings
  rawPrompt         String?   // optional, for debugging
  tokenInputCount   Int
  tokenOutputCount  Int
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@index([shotId])
}

model Tag {
  id    String  @id @default(uuid())
  name  String  @unique
  shots Shot[]
}

model Settings {
  key   String @id
  value String
}
